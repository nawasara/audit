{
    "name": "nawasara/audit",
    "description": "Audit trail, activity logging, and login attempt tracking for the Nawasara superapp framework.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "nawasara",
        "laravel",
        "audit",
        "activity-log",
        "login-history",
        "compliance"
    ],
    "authors": [
        {
            "name": "Pringgo J. Saputro",
            "email": "odyinggo@gmail.com",
            "role": "Lead Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/nawasara/audit/issues",
        "source": "https://github.com/nawasara/audit"
    },
    "autoload": {
        "psr-4": {
            "Nawasara\\Audit\\": "src/"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^12.0",
        "spatie/laravel-activitylog": "^4.9",
        "nawasara/ui": "*",
        "livewire/livewire": "^3.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nawasara\\Audit\\AuditServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
